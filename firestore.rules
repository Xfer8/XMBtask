rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in
          get(/databases/$(database)/documents/config/allowedUsers).data.admins;
    }

    // Whitelist — any authenticated user may read; only admins may write
    match /config/allowedUsers {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Feature flags — any authenticated user may read; only admins may write
    match /config/featureFlags {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Access requests — anyone may submit; only admins may read/delete
    match /accessRequests/{requestId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Feedback — any authenticated user may submit; only admins may read/delete
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }

    // User data — only accessible by the owner
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
